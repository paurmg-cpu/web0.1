---
export interface Props {
  telefono?: string;
  email?: string;
  direccion?: string;
  whatsapp?: string;
  instagram?: string;
  facebook?: string;
}
const {
  telefono = '+34 XXX XXX XXX',
  email = 'info@vetamans.com',
  direccion = 'Gandia, Valencia - Marina Alta',
  whatsapp = '34XXXXXXXXX',
  instagram = '',
  facebook = '',
} = Astro.props;
---
<footer class="bg-vetamans-carbon text-vetamans-lino/80 pt-20 pb-8">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Marca -->
      <div class="md:col-span-1">
        <div class="text-2xl font-serif font-bold text-vetamans-lino mb-4">VETAMANS</div>
        <p class="font-light text-sm leading-relaxed text-vetamans-lino/60">
          Maestría y pasión en ebanistería de lujo. Especialistas en cocinas a medida, muebles personalizados y restauración en Gandia y la Marina Alta.
        </p>
      </div>

      <!-- Enlaces -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-vetamans-lino mb-4">Navegación</h3>
        <ul class="space-y-2 text-sm font-light">
          <li><a href="/" class="hover:text-vetamans-roble transition-colors">Inicio</a></li>
          <li><a href="/servicios" class="hover:text-vetamans-roble transition-colors">Servicios</a></li>
          <li><a href="/portfolio" class="hover:text-vetamans-roble transition-colors">Portfolio</a></li>
          <li><a href="/nosotros" class="hover:text-vetamans-roble transition-colors">Nosotros</a></li>
          <li><a href="/contacto" class="hover:text-vetamans-roble transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Servicios -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-vetamans-lino mb-4">Servicios</h3>
        <ul class="space-y-2 text-sm font-light">
          <li><a href="/servicios/cocinas" class="hover:text-vetamans-roble transition-colors">Cocinas a Medida</a></li>
          <li><a href="/servicios/medida" class="hover:text-vetamans-roble transition-colors">Muebles a Medida</a></li>
          <li><a href="/servicios/restauracion" class="hover:text-vetamans-roble transition-colors">Restauración</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-vetamans-lino mb-4">Contacto</h3>
        <ul class="space-y-3 text-sm font-light">
          <li class="flex items-start gap-2">
            <span class="text-vetamans-roble mt-0.5">📍</span>
            <span>{direccion}</span>
          </li>
          <li>
            <a href={`mailto:${email}`} class="hover:text-vetamans-roble transition-colors flex items-start gap-2">
              <span class="text-vetamans-roble mt-0.5">✉️</span>
              <span>{email}</span>
            </a>
          </li>
          <li>
            <a href={`https://wa.me/${whatsapp}`} class="hover:text-vetamans-roble transition-colors flex items-start gap-2">
              <span class="text-vetamans-roble mt-0.5">📱</span>
              <span>WhatsApp</span>
            </a>
          </li>
          {instagram && (
            <li>
              <a href={instagram} target="_blank" rel="noopener" class="hover:text-vetamans-roble transition-colors flex items-start gap-2">
                <span class="text-vetamans-roble mt-0.5">📷</span>
                <span>Instagram</span>
              </a>
            </li>
          )}
          {facebook && (
            <li>
              <a href={facebook} target="_blank" rel="noopener" class="hover:text-vetamans-roble transition-colors flex items-start gap-2">
                <span class="text-vetamans-roble mt-0.5">📘</span>
                <span>Facebook</span>
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div class="border-t border-vetamans-lino/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-vetamans-lino/40">
      <p>&copy; {new Date().getFullYear()} Vetamans. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="/aviso-legal" class="hover:text-vetamans-lino/60 transition-colors">Aviso Legal</a>
        <a href="/privacidad" class="hover:text-vetamans-lino/60 transition-colors">Política de Privacidad</a>
        <a href="/cookies" class="hover:text-vetamans-lino/60 transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
