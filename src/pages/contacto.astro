---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contacto y Presupuestos"
  description="Solicita tu presupuesto sin compromiso. Cuéntanos tu proyecto de carpintería a medida, cocina, restauración o mueble personalizado. Taller en Gandia, Valencia. Servimos toda la Marina Alta."
  canonicalURL="https://vetamans.com/contacto"
>
  <Nav currentPage="/contacto" />
  <main class="pt-24 px-8 max-w-7xl mx-auto">
    <section class="py-20 flex flex-col lg:flex-row gap-16">
      <!-- Columna de Información -->
      <div class="lg:w-1/3">
        <h1 class="text-4xl md:text-5xl font-serif text-vetamans-nogal mb-6 leading-tight">
          Hablemos de tu <br/> <span class="italic">próximo proyecto</span>
        </h1>
        <p class="text-vetamans-carbon font-light text-lg mb-12 leading-relaxed">
          Cada proyecto comienza con una conversación. Cuéntanos tu idea y transformémosla en una pieza duradera y funcional.
        </p>

        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="text-vetamans-roble text-2xl" aria-hidden="true">📍</div>
            <div>
              <h3 class="font-bold text-vetamans-nogal">Ubicación</h3>
              <p class="text-vetamans-carbon font-light">Gandia, Valencia / Marina Alta</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="text-vetamans-roble text-2xl" aria-hidden="true">📱</div>
            <div>
              <h3 class="font-bold text-vetamans-nogal">WhatsApp / Teléfono</h3>
              <a href="https://wa.me/34XXXXXXXXX" class="text-vetamans-carbon font-light hover:text-vetamans-roble transition-colors">+34 XXX XXX XXX</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="text-vetamans-roble text-2xl" aria-hidden="true">✉️</div>
            <div>
              <h3 class="font-bold text-vetamans-nogal">Email</h3>
              <a href="mailto:info@vetamans.com" class="text-vetamans-carbon font-light hover:text-vetamans-roble transition-colors">info@vetamans.com</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna del Formulario -->
      <div class="lg:w-2/3 bg-white p-8 md:p-12 rounded-sm shadow-sm border border-vetamans-roble/20">
        <form id="contact-form" class="space-y-8" novalidate>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="nombre" class="text-sm font-semibold text-vetamans-carbon uppercase tracking-wider">Nombre Completo</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Ej. Juan Pérez" class="bg-vetamans-lino border-b border-vetamans-roble/40 p-3 focus:outline-none focus:border-vetamans-nogal transition-colors" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="text-sm font-semibold text-vetamans-carbon uppercase tracking-wider">Email de contacto</label>
              <input type="email" id="email" name="email" required placeholder="juan@ejemplo.com" class="bg-vetamans-lino border-b border-vetamans-roble/40 p-3 focus:outline-none focus:border-vetamans-nogal transition-colors" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="telefono" class="text-sm font-semibold text-vetamans-carbon uppercase tracking-wider">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="Ej. 600 111 222" class="bg-vetamans-lino border-b border-vetamans-roble/40 p-3 focus:outline-none focus:border-vetamans-nogal transition-colors" />
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <label class="text-sm font-semibold text-vetamans-carbon uppercase tracking-wider">¿Qué servicio necesitas?</label>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <label class="cursor-pointer group">
                <input type="radio" name="servicio" value="cocinas" class="hidden peer" />
                <div class="p-4 text-center border border-vetamans-roble/30 rounded-sm peer-checked:bg-vetamans-nogal peer-checked:text-vetamans-lino transition-all group-hover:border-vetamans-nogal">
                  Cocinas
                </div>
              </label>
              <label class="cursor-pointer group">
                <input type="radio" name="servicio" value="muebles-medida" class="hidden peer" />
                <div class="p-4 text-center border border-vetamans-roble/30 rounded-sm peer-checked:bg-vetamans-nogal peer-checked:text-vetamans-lino transition-all group-hover:border-vetamans-nogal">
                  Muebles Medida
                </div>
              </label>
              <label class="cursor-pointer group">
                <input type="radio" name="servicio" value="restauracion" class="hidden peer" />
                <div class="p-4 text-center border border-vetamans-roble/30 rounded-sm peer-checked:bg-vetamans-nogal peer-checked:text-vetamans-lino transition-all group-hover:border-vetamans-nogal">
                  Restauración
                </div>
              </label>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="mensaje" class="text-sm font-semibold text-vetamans-carbon uppercase tracking-wider">Cuéntanos tu idea</label>
            <textarea id="mensaje" name="mensaje" required rows="4" placeholder="Describe el proyecto, medidas aproximadas, materiales preferidos..." class="bg-vetamans-lino border border-vetamans-roble/40 p-3 focus:outline-none focus:border-vetamans-nogal transition-colors"></textarea>
          </div>

          <!-- Feedback message -->
          <div id="form-feedback" class="hidden text-sm font-medium p-4 rounded-sm"></div>

          <button type="submit" class="w-full bg-vetamans-nogal text-vetamans-lino py-4 rounded-sm font-semibold text-lg hover:bg-vetamans-carbon transition-all shadow-lg uppercase tracking-widest disabled:opacity-60 disabled:cursor-not-allowed" id="form-submit">
            Enviar Solicitud de Presupuesto
          </button>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form');
  const feedback = document.getElementById('form-feedback');
  const submitBtn = document.getElementById('form-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = submitBtn;
    const originalText = btn?.textContent;

    // Validación
    const nombre = form.nombre?.value.trim();
    const email = form.email?.value.trim();
    const mensaje = form.mensaje?.value.trim();

    if (!nombre || !email || !mensaje) {
      showFeedback('Por favor, completa todos los campos obligatorios.', 'error');
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      showFeedback('Por favor, introduce un email válido.', 'error');
      return;
    }

    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Enviando...';
    }

    try {
      const res = await fetch('https://api.vetamans.com/api/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nombre,
          email,
          telefono: form.telefono?.value.trim() || '',
          mensaje,
          servicio: form.servicio?.value || null,
          origen: 'web',
        }),
      });

      if (!res.ok) throw new Error('Error del servidor');

      showFeedback('¡Gracias por tu solicitud! Te contactaremos en 24-48 horas.', 'success');
      form.reset();
    } catch {
      showFeedback('Hubo un error al enviar. Inténtalo de nuevo o escríbenos directamente.', 'error');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }
  });

  function showFeedback(msg, type) {
    if (!feedback) return;
    feedback.textContent = msg;
    feedback.classList.remove('hidden');
    feedback.classList.remove('bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800');
    if (type === 'success') {
      feedback.classList.add('bg-green-100', 'text-green-800');
    } else {
      feedback.classList.add('bg-red-100', 'text-red-800');
    }
    // Auto-ocultar éxito
    if (type === 'success') {
      setTimeout(() => feedback.classList.add('hidden'), 6000);
    }
  }
</script>
