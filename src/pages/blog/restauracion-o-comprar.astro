  'headline': '¿Restaurar o comprar nuevo? La guía definitiva para decidir',
  'description': 'Analizamos cuándo merece la pena restaurar un mueble antiguo y cuándo es mejor comprar uno nuevo. Factores como el valor sentimental, la calidad de la madera y el coste de restauración.',
  'author': { '@type': 'Person', 'name': 'Vetamans' },
  'publisher': { '@type': 'Organization', 'name': 'Vetamans', 'logo': { '@type': 'ImageObject', 'url': 'https://www.vetamans.com/og-image.jpg' } },
  'datePublished': '2025-04-20',
  'dateModified': '2025-04-20',
