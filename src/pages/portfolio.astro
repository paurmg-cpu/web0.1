---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

let proyectos = [];
try {
  const res = await fetch('https://api.vetamans.com/api/proyectos');
  if (res.ok) proyectos = await res.json();
} catch (e) {}

// Agrupar por categoría
const categorias: Record<string, any[]> = {};
proyectos.forEach(p => {
  if (!categorias[p.categoria]) categorias[p.categoria] = [];
  categorias[p.categoria].push(p);
});

const categoriaLabels: Record<string, string> = {
  cocinas: 'Cocinas Integrales',
  vestidores: 'Vestidores y Almacenaje',
  exteriores: 'Estructuras y Exteriores',
  restauracion: 'Restauración de Alta Gama',
};
---

<Layout
  title="Portfolio"
  description="Galería de proyectos de ebanistería artesanal. Cocinas integrales, vestidores a medida, pérgolas y estructuras de madera. Cada pieza es una obra única diseñada y fabricada en nuestro taller de Gandia."
  canonicalURL="https://www.vetamans.com/portfolio"
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Portfolio', url: '/portfolio' }]}
>
  <Nav currentPage="/portfolio" />
  <main class="pt-24 px-8 max-w-7xl mx-auto">
    <section class="py-20">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-serif text-vetamans-nogal mb-4">Nuestras Obras</h1>
        <p class="text-vetamans-carbon font-light max-w-2xl mx-auto">
          Cada pieza es el resultado de horas de precisión, respeto por la materia prima y una búsqueda constante de la perfección.
        </p>
      </div>

      {proyectos.length === 0 ? (
        <p class="text-center text-vetamans-carbon/60 py-20">Pronto mostraremos nuestros proyectos aquí.</p>
      ) : (
        <div class="space-y-24">
          {Object.entries(categorias).map(([cat, items]) => (
            <div>
              <div class="flex items-center gap-4 mb-8">
                <h2 class="text-2xl font-serif text-vetamans-nogal">{categoriaLabels[cat] || cat}</h2>
                <div class="flex-1 h-px bg-vetamans-roble/30"></div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {items.map(p => (
                  <div class="group overflow-hidden relative aspect-square bg-vetamans-roble/10 rounded-sm">
                    {p.imagenes?.[0] ? (
                      <img src={p.imagenes[0]} alt={p.titulo} loading="lazy" decoding="async" width="600" height="600" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-4xl">🪵</div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-vetamans-carbon/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                      <div>
                        <p class="text-white font-semibold text-sm">{p.titulo}</p>
                        {p.cliente && <p class="text-white/70 text-xs mt-1">{p.cliente}</p>}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </main>
  <Footer />
</Layout>
