---
interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  image?: string;
  pageType?: string;
  noindex?: boolean;
  preloadImage?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  whatsapp?: string;
}

const {
  title,
  description = 'Vetamans: Maestría y pasión en ebanistería de lujo. Especialistas en cocinas a medida, muebles personalizados y restauración de alta gama en Gandia y Valencia.',
  canonicalURL = 'https://www.vetamans.com',
  image = '/og-image.jpg',
  pageType = 'WebPage',
  noindex = false,
  preloadImage = '',
  breadcrumbs = [],
  whatsapp = '34XXXXXXXXX',
} = Astro.props;

const baseUrl = 'https://www.vetamans.com';

// LocalBusiness Schema
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  'name': 'Vetamans',
  'description': description,
  'url': baseUrl,
  'telephone': '+34-XXX-XXX-XXX',
  'email': 'info@vetamans.com',
  'image': `${baseUrl}${image}`,
  'priceRange': '€€€',
  'currenciesAccepted': 'EUR',
  'paymentAccepted': 'Cash, Credit Card, Wire Transfer',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': 'Calle de la Madera, 12',
    'addressLocality': 'Gandia',
    'addressRegion': 'Valencia',
    'postalCode': '46701',
    'addressCountry': 'ES',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': 38.9667,
    'longitude': -0.1833,
  },
  'areaServed': [
    { '@type': 'City', 'name': 'Gandia' },
    { '@type': 'City', 'name': 'Valencia' },
    { '@type': 'AdministrativeArea', 'name': 'Marina Alta' },
    { '@type': 'AdministrativeArea', 'name': 'La Safor' },
  ],
  'openingHoursSpecification': [
    { '@type': 'OpeningHoursSpecification', 'dayOfWeek': ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], 'opens': '08:00', 'closes': '18:00' },
    { '@type': 'OpeningHoursSpecification', 'dayOfWeek': 'Saturday', 'opens': '09:00', 'closes': '13:00' },
  ],
  'sameAs': [
    'https://www.instagram.com/vetamans',
    'https://www.facebook.com/vetamans',
  ],
  'hasOfferCatalog': {
    '@type': 'OfferCatalog',
    'name': 'Servicios de Carpintería',
    'itemListElement': [
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', 'name': 'Cocinas a Medida', 'description': 'Diseño y fabricación artesanal de cocinas integrales de lujo' }, 'areaServed': { '@type': 'City', 'name': 'Gandia' } },
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', 'name': 'Muebles a Medida', 'description': 'Mobiliario personalizado con maderas nobles y ensambles tradicionales' } },
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', 'name': 'Restauración de Muebles', 'description': 'Restauración profesional con técnicas tradicionales de ebanistería' } },
    ],
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="keywords" content="carpintería Gandia, muebles a medida Valencia, ebanistería de lujo, restauración de muebles Gandia, cocinas a medida Marina Alta" />
    <meta name="author" content="Vetamans" />
    <meta name="geo.region" content="ES-VC" />
    <meta name="geo.placename" content="Gandia" />
    <meta name="geo.position" content="38.9667;-0.1833" />
    <meta name="ICBM" content="38.9667, -0.1833" />
    {noindex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <title>{title} | Vetamans - Ebanistería de Lujo</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Vetamans - Ebanistería de Lujo`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `${baseUrl}${image}`} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Vetamans" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} | Vetamans - Ebanistería de Lujo`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `${baseUrl}${image}`} />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)}></script>

    <!-- BreadcrumbList Schema -->
    {breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        'itemListElement': breadcrumbs.map((b, i) => ({
          '@type': 'ListItem',
          'position': i + 1,
          'item': { '@id': b.url.startsWith('http') ? b.url : `${baseUrl}${b.url}`, 'name': b.name },
        })),
      })}></script>
    )}
  </head>
  <body class="bg-vetamans-lino text-vetamans-carbon font-sans scroll-smooth antialiased">
    <slot />
    <!-- WhatsApp Floating Button -->
    <a href={`https://wa.me/${whatsapp}`} target="_blank" rel="noopener" aria-label="Contactar por WhatsApp" class="fixed bottom-6 right-6 z-50 bg-green-500 text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg hover:bg-green-600 hover:scale-110 transition-all duration-300" style="box-shadow: 0 4px 20px rgba(37,211,102,.4);">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.97-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-2.643-1.025-5.128-2.896-6.994-1.866-1.865-4.35-2.896-6.994-2.897-5.452 0-9.887 4.434-9.889 9.885 0 1.766.474 3.511 1.357 5.033l.908 1.577-.576 2.106 2.226-.54 1.583.884z"/></svg>
    </a>
    <!-- Cookie Banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 w-full bg-vetamans-carbon text-vetamans-lino p-4 z-40 hidden shadow-2xl">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <p class="font-light">Utilizamos cookies propias y de terceros para mejorar tu experiencia. Al continuar navegando aceptas nuestra <a href="/privacidad" class="underline hover:text-vetamans-roble">política de privacidad</a>.</p>
        <button onclick="document.getElementById('cookie-banner').classList.add('hidden'); localStorage.setItem('cookies_accepted','1')" class="bg-vetamans-roble text-vetamans-lino px-6 py-2 rounded-sm font-semibold text-sm whitespace-nowrap hover:bg-vetamans-nogal transition-colors">Aceptar</button>
      </div>
    </div>
    <script>
      if (!localStorage.getItem('cookies_accepted')) document.getElementById('cookie-banner').classList.remove('hidden');
    </script>
  </body>
</html>
